# EditorConfig — https://editorconfig.org
# Shared across all platforms; respected by every major IDE.

root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts,java}]
indent_size = 4
max_line_length = 120

[*.swift]
indent_size = 4
max_line_length = 120

[*.{js,jsx,ts,tsx,json,yaml,yml,css,scss,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.gradle]
indent_size = 4

[*.xml]
indent_size = 2
