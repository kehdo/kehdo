# kehdo web — environment variables example
# Copy to .env.local for development. Never commit real secrets.

# Waitlist storage — Google Apps Script web-app webhook URL
# Setup:
#   1. Create a Google Sheet titled "kehdo waitlist" with headers
#      in row 1: Email | Source | Timestamp
#   2. Extensions → Apps Script → paste a doPost(e) handler that
#      parses the JSON body and appends a row to the sheet
#      (dedupe by column A; see /docs/SETUP.md for the script)
#   3. Deploy → New deployment → Web app
#      - Execute as: Me
#      - Who has access: Anyone
#   4. Authorize the script and copy the deployment URL
#      (https://script.google.com/macros/s/.../exec)
GOOGLE_SHEET_WEBHOOK_URL=

# Analytics: Vercel Web Analytics (free on Hobby plan, no cookies, no env var
# required — auto-detects when running in Vercel and sends events to the
# project's Analytics tab once enabled in the Vercel dashboard).

# API endpoint
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1
